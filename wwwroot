<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Notification Service</title>
</head>
<body>
    <h1>Notification Service</h1>
    <button id="login-button">Login</button>
    <button id="logout-button" style="display: none;">Logout</button>
    <div id="notifications"></div>

    <script>
        let userId = null;
        let notificationContainer = document.getElementById('notifications');

        // Login button click handler
        document.getElementById('login-button').addEventListener('click', async () => {
            try {
                const response = await fetch('/login', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({ UserName: 'YourUsername' })
                });

                if (response.ok) {
                    const data = await response.json();
                    userId = data.id;
                    document.getElementById('login-button').style.display = 'none';
                    document.getElementById('logout-button').style.display = 'inline-block';
                } else {
                    console.error('Failed to login');
                }
            } catch (error) {
                console.error('Error logging in:', error);
            }
        });

        // Logout button click handler
        document.getElementById('logout-button').addEventListener('click', async () => {
            try {
                const response = await fetch('/logout', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({ UserId: userId })
                });

                if (response.ok) {
                    userId = null;
                    document.getElementById('login-button').style.display = 'inline-block';
                    document.getElementById('logout-button').style.display = 'none';
                } else {
                    console.error('Failed to logout');
                }
            } catch (error) {
                console.error('Error logging out:', error);
            }
        });

        // Establish SSE connection
        if ('EventSource' in window) {
            const eventSource = new EventSource(`/sse/${userId}`);

            eventSource.onmessage = event => {
                const notification = JSON.parse(event.data);
                const notificationHTML = `
                    <div>
                        <h2>${notification.title}</h2>
                        <p>${notification.body}</p>
                        <button id="read-button-${notification.id}">Mark as Read</button>
                    </div>
                `;

                notificationContainer.innerHTML += notificationHTML;

                // Mark as read button click handler
                document.getElementById(`read-button-${notification.id}`).addEventListener('click', async () => {
                    try {
                        const response = await fetch('/read', {
                            method: 'POST',
                            headers: {
                                'Content-Type': 'application/json'
                            },
                            body: JSON.stringify({ UserId: userId, NotificationId: notification.id })
                        });

                        if (response.ok) {
                            console.log(`Notification ${notification.id} marked as read`);
                        } else {
                            console.error(`Failed to mark notification ${notification.id} as read`);
                        }
                    } catch (error) {
                        console.error(`Error marking notification ${notification.id} as read:`, error);
                    }
                });
            };

            eventSource.onerror = () => {
                console.error('Error occurred while receiving notifications');
            };

            eventSource.onopen = () => {
                console.log('Connected to notification service');
            };

            eventSource.onerror = () => {
                console.error('Error occurred while receiving notifications');
            };

            eventSource.onclose = () => {
                console.log('Disconnected from notification service');
            };
        } else {
            console.error('Your browser does not support Server-Sent Events');
        }
    </script>
</body>
</html>